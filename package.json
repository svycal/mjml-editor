{
  "name": "mjml-editor-workspace",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter playground dev",
    "dev:lib": "pnpm --filter @savvycal/mjml-editor dev",
    "dev:concurrent": "concurrently \"pnpm --filter @savvycal/mjml-editor dev\" \"pnpm --filter playground dev\"",
    "build": "pnpm --filter @savvycal/mjml-editor build && pnpm --filter playground build",
    "build:lib": "pnpm --filter @savvycal/mjml-editor build",
    "typecheck": "pnpm --filter @savvycal/mjml-editor typecheck && pnpm --filter @savvycal/mjml-editor build && pnpm --filter playground typecheck",
    "lint": "eslint .",
    "preview": "pnpm --filter playground preview",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build:lib && changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.29.8",
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "prettier": "^3.7.4",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4"
  },
  "pnpm": {
    "overrides": {
      "@isaacs/brace-expansion": "^5.0.1",
      "ajv@>=7.0.0-alpha.0 <8.18.0": "^8.18.0",
      "diff@>=6.0.0 <8.0.3": "^8.0.3",
      "flatted": "^3.4.2",
      "lodash": "^4.18.1",
      "markdown-it@>=13.0.0 <14.1.1": "^14.1.1",
      "minimatch@<3.1.3": "^3.1.3",
      "minimatch@>=9.0.0 <9.0.7": "^9.0.7",
      "minimatch@>=10.0.0 <10.2.3": "^10.2.3",
      "picomatch@<2.3.2": "^2.3.2",
      "picomatch@>=4.0.0 <4.0.4": "^4.0.4",
      "postcss@<8.5.10": "^8.5.10",
      "rollup@>=4.0.0 <4.59.0": "^4.59.0"
    }
  }
}
